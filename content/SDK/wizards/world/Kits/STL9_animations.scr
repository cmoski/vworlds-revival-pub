	set obj = world.createinstance("cube","artifact", AnimationRoom)
	obj.label = "animate cube"
	obj.description = "This cube does a simple position animation when you click on it."
	obj.initializegraphics "SDK/library/models/shapes/cube.x" , 1,1,25,1,0,0
	obj.renderquality = 3
	obj.CreateAndAddMethod world.METHOD_CLIENT, Lesson_9_Module, "cube_onLButtonUp", "onLButtonUp",  , world.PS_ALL_E + world.PS_ALL_RWA
	obj.CreateAndAddMethod world.METHOD_CLIENT, Lesson_9_Module, "cube_animationDone", "animationDone",  , world.PS_ALL_E + world.PS_ALL_RWA
	' Create a property map for a simple position animation
	obj.addproperty "simpleAnimMap", world.createPropertyMap
	obj.simpleAnimMap.property("0") = world.createVector(1,1,25)
	obj.simpleAnimMap.property("1") = world.createVector(1,4,30)
	obj.simpleAnimMap.property("2") = world.createVector(1,5,35)
	obj.simpleAnimMap.property("3") = world.createVector(1,4,45)
	obj.simpleAnimMap.property("4") = world.createVector(1,1,50)
	obj.simpleAnimMap.property("8") = world.createVector(1,1,25)
	world.global.addProperty "cube", obj
	
	set obj = world.createinstance("directionalLight","Light", AnimationRoom)
	obj.label = "animate light color"
	obj.description = "A directional light; casts parallel light on all objects, as if from an infinitely distant source. The direction of this object determines the direction of the lighting; its position has no effect."
	obj.initializegraphics "SDK/library/models/shapes/artifact.x" , -5,4,17, 0.9, 0.0, -0.3
	obj.lightType = 3
	obj.lightColor = world.createVector(0.4,0.4,1)
	obj.lightAttenuation = world.createVector(1,0,0)
	obj.CreateAndAddMethod world.METHOD_CLIENT, Lesson_9_Module, "directionalLight_onLButtonUp", "onLButtonUp",  , world.PS_ALL_E + world.PS_ALL_RWA
	' Create a property map for a light animation, using rgb values in the vectors
	obj.addproperty "lightAnimMap", world.createPropertyMap
	obj.lightAnimMap.property("0") = world.createVector(0.4,0.4,1)
	obj.lightAnimMap.property("2000") = world.createVector(1,0,0)
	obj.lightAnimMap.property("3000") = world.createVector(1,1,0)
	obj.lightAnimMap.property("4000") = world.createVector(0,1,0)
	obj.lightAnimMap.property("5000") = world.createVector(0,1,1)
	obj.lightAnimMap.property("6000") = world.createVector(0,0,1)
	obj.lightAnimMap.property("7000") = world.createVector(1,0,1)
	obj.lightAnimMap.property("8000") = world.createVector(1,1,1)
	obj.lightAnimMap.property("9000") = world.createVector(0.4,0.4,1)
	world.global.addProperty "directionalLight", obj
	
