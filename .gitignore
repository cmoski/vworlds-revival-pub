# Build directories
build*/
Debug/
Release/
ReleaseMinSize/
x64/

# Visual Studio
*.suo
*.user
*.ncb
*.sdf
*.opensdf
*.vc.db
*.vc.opendb
.vs/

# CMake
CMakeSettings.json

# Generated MIDL outputs (regenerated by build)
# Keep the .idl files, ignore generated .h/_i.c/_p.c from MIDL
# Note: vwcommon/ generated headers ARE tracked since some have manual edits

# Compiled objects
*.obj
*.pch
*.idb
*.pdb
*.ilk
*.exp
*.res
*.tlb
*.manifest

# DLLs and executables (build outputs)
*.dll
*.exe
*.lib

# Exception: third_party runtime files needed for build
!third_party/d3drm_legacy/x86/lib/*.lib
!third_party/d3drm_legacy/x86/bin/*.dll

# Temporary files
*.tmp
*.log
*.tlog

# Claude settings
.claude/
